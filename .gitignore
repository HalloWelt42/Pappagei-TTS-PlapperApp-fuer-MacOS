# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# Swift / build artifacts
.build/
.swiftpm/
DerivedData/
*.app/

# Generated audio and logs (not source)
*.wav
*.mp3
*.flac
*.ogg
*.m4a
*.aiff
*.log

