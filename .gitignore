# User-provided reference recordings (kept local)
voices_in/

# macOS clutter
.DS_Store
.AppleDouble
Icon?
# 'Icon?' targets Finder custom-icon files but also matches the icons/
# directory (case-insensitive); keep the extension icons in the repo.
!extension/icons/
